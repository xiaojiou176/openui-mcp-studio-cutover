		".devcontainer",
		".githooks",
		".github",
		".kubelinter",
		"apps",
		"contracts",
		"docs",
		"examples",
		"ops",
		"packages",
		"plugins",
		"services",
		"tests",
		"tooling"
	],
	"trackedFiles": [
		".gitignore",
		".gitleaks.toml",
		".golangci.yml",
		".markdownlint.json",
		".node-version",
		".nvmrc",
		".pre-commit-config.yaml",
		".stylelintrc.json",
		".typos.toml",
		"AGENTS.md",
		"biome.json",
		"CHANGELOG.md",
		"CLAUDE.md",
		"CODEOWNERS",
		"CODE_OF_CONDUCT.md",
		"commitlint.config.cjs",
		"CONTRIBUTING.md",
		"DISTRIBUTION.md",
		"eslint.config.mjs",
		"INTEGRATIONS.md",
		"LICENSE",
		"manifest.yaml",
		"package-lock.json",
		"package.json",
		"playwright.config.ts",
		"pyproject.toml",
		"README.md",
		"SECURITY.md",
		"SUPPORT.md",
		"tsconfig.json",
		"vitest.config.ts",
		".env.development.example",
		".env.example",
		".env.production.example",
		".env.staging.example"
	],
	"machineManagedInstallSurface": ["node_modules"],
	"containerOnlyInstallSurface": ["node_modules"],
	"machineManagedRuntimeSurface": [".runtime-cache"],
	"localDevelopmentDirectories": [
		".agent",
		".agents",
		".conductor",
		".serena",
		".vscode"
	],
	"localDevelopmentFiles": [".cursorrules", ".DS_Store", ".env", "orb.db"],
	"forbiddenPatterns": [
		"tmp*",
		"misc*",
		"backup*",
		"final*",
		"*.log"
	]
