{
	"bin": {
		"openui-mcp-studio": "./tooling/cli/openui.mjs"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.1",
		"zod": "^4.3.6"
	},
	"description": "Local stdio MCP server and repo-aware workflow for generating, applying, and verifying React + shadcn UI from natural-language briefs.",
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.3.5",
		"@types/pngjs": "^6.0.5",
		"@vitest/coverage-istanbul": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"@vitest/eslint-plugin": "^1.6.14",
		"axe-core": "^4.11.0",
		"eslint": "^10.1.0",
		"jscpd": "^4.0.8",
		"markdownlint-cli": "^0.48.0",
		"patch-package": "^8.0.1",
		"pixelmatch": "^7.1.0",
		"playwright": "^1.56.1",
		"pngjs": "^7.0.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.56.1",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": "22.22.0"
	},
	"exports": {
		".": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/builder-surface.js",
		"./public": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/builder-surface.js",
		"./public/builder-surface": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/builder-surface.js",
		"./public/computer-use": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/computer-use.js",
		"./public/compat-api": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/compat-api.js",
		"./public/ecosystem-surface": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/ecosystem-surface.js",
		"./public/next-smoke": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/next-smoke.js",
		"./public/openui-client": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/openui-client.js",
		"./public/provider-testing": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/provider-testing.js",
		"./public/server": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/server.js",
		"./public/ship": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/ship.js",
		"./public/skills-surface": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/skills-surface.js",
		"./public/sdk": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/sdk.js",
		"./public/tool-shared": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/tool-shared.js",
		"./public/uiux-audit-foundation": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/uiux-audit-foundation.js",
		"./public/visual-diff": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/visual-diff.js",
		"./public/workflow-summary": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/workflow-summary.js",
		"./sdk": "./.runtime-cache/build/mcp-server/services/mcp-server/src/public/sdk.js",
		"./cli": "./tooling/cli/openui.mjs",
		"./package.json": "./package.json"
	},
	"keywords": [
		"agent-tools",
		"mcp",
		"mcp-server",
		"nextjs",
		"openui",
		"quality-gates",
		"react",
		"shadcn",
		"tailwind",
		"ui-generation",
		"ui-ux",
		"codex",
		"claude-code"
	],
	"license": "MIT",
	"main": ".runtime-cache/build/mcp-server/services/mcp-server/src/main.js",
	"name": "openui-mcp-studio",
	"workspaces": [
		"apps/*",
		"packages/*",
		"services/mcp-server"
	],
	"overrides": {
		"brace-expansion": "5.0.5",
		"minimatch": "10.2.4",
		"path-to-regexp": "8.4.0",
		"hono": "4.12.8",
		"@hono/node-server": "1.19.11",
		"flatted": "3.4.2"
	},
	"private": true,
	"scripts": {
		"audit": "npm audit --audit-level=high",
		"build": "tsc -p tsconfig.json",
		"ci:acceptance:gate": "npm run docs:completeness:check && npm run test:acceptance:gate",
		"ci:gate": "node --env-file-if-exists=.env tooling/ci-gate.mjs",
		"ci:gate:container": "node tooling/check-container-env.mjs --require-container && npm run ci:gate",
		"ci:local:container": "bash ops/ci-container/run-in-container.sh --command \"npm run ci:gate:container\"",
		"ci:local:container:bootstrap": "OPENUI_CI_ALLOW_LOCAL_BOOTSTRAP=1 bash ops/ci-container/run-in-container.sh --command \"npm run ci:gate:container\"",
		"clean:runtime": "node tooling/clean-runtime.mjs",
		"clean:runtime:full": "node tooling/clean-runtime.mjs --include-e2e-artifacts",
		"clean:runtime:check": "node --input-type=module -e \"import path from 'node:path'; const cwd = process.cwd(); const workspacePrefix = cwd + path.sep; const targets = ['.runtime-cache/runs', '.runtime-cache/cache', '.runtime-cache/build', '.runtime-cache/reports/quality-trend', '.runtime-cache/reports/history-audit', '.runtime-cache/reports/release-readiness', '.runtime-cache/reports/security', '.runtime-cache/reports/upstream'].map((dir) => path.resolve(cwd, dir)); const outsideWorkspace = targets.filter((target) => !target.startsWith(workspacePrefix)); if (outsideWorkspace.length > 0) { console.error(JSON.stringify({ ok: false, reason: 'unsafe-target', outsideWorkspace }, null, 2)); process.exit(1); } console.log(JSON.stringify({ ok: true, mode: 'dry-run-equivalent', targets }, null, 2));\"",
		"commitlint": "commitlint --from HEAD~1 --to HEAD --verbose",
		"commitlint:last": "commitlint --from HEAD~1 --to HEAD",
		"container:check": "node tooling/check-container-env.mjs",
		"deps:outdated": "node tooling/deps-outdated.mjs",
		"demo:ship": "node --env-file-if-exists=.env --import tsx tooling/demo-ship.ts",
		"dev": "node --env-file-if-exists=.env --import tsx services/mcp-server/src/main.ts",
		"dev:container": "node tooling/check-container-env.mjs --require-container && npm run dev",
		"docs:check": "npm run docs:lint && npm run docs:consistency:check",
		"docs:check:strict": "npm run docs:check && npm run docs:manual-fact:check && npm run proof:pack:check",
		"docs:completeness:check": "node tooling/check-doc-completeness.mjs",
		"docs:consistency:check": "npm run docs:linkcheck && npm run docs:scope:check",
		"docs:linkcheck": "node tooling/docs-linkcheck.mjs",
		"docs:manual-fact:check": "node tooling/check-docs-manual-boundary.mjs",
		"docs:lint": "markdownlint --config .markdownlint.json \"README.md\" \"docs/**/*.md\"",
		"docs:scope:check": "node tooling/check-docs-scope.mjs",
		"env:check": "node tooling/verify-env-contract.mjs",
		"env:governance:check": "node tooling/verify-env-governance.mjs",
		"env:governance:report": "node tooling/env-governance-report.mjs",
		"env:keyset:drift": "node tooling/env-keyset-drift.mjs",
		"file:governance": "node tooling/check-file-governance.mjs",
		"governance:check": "npm run governance:final:check",
		"governance:contract:check": "node tooling/check-governance-contract.mjs",
		"governance:identity-alignment:check": "node tooling/check-identity-alignment.mjs",
		"governance:ssot:check": "node tooling/check-ssot.mjs",
		"governance:topology:check": "node tooling/check-topology.mjs",
		"governance:public-surface:check": "node tooling/check-public-surfaces.mjs",
		"governance:module-readme:check": "node tooling/check-module-readme.mjs",
		"governance:root:check": "node tooling/check-root-allowlist.mjs",
		"governance:root-pristine:check": "node tooling/check-root-pristine.mjs",
		"governance:deps:check": "node tooling/check-dependency-boundaries.mjs",
		"governance:delivery-surface:check": "node tooling/check-delivery-surface.mjs",
		"governance:history-hygiene:check": "bash tooling/history-hygiene-check.sh",
		"governance:runtime:check": "node tooling/check-runtime-governance.mjs",
		"governance:runtime-layout:check": "node tooling/check-runtime-layout.mjs",
		"governance:cache-lifecycle:check": "node tooling/check-cache-lifecycle.mjs",
		"host:safety:check": "node tooling/check-host-safety.mjs",
		"governance:space:check": "node --env-file-if-exists=.env tooling/check-space-governance.mjs && node --env-file-if-exists=.env tooling/check-space-path-sources.mjs",
		"governance:upstream-policy:check": "node tooling/check-upstream-policy-alignment.mjs",
		"governance:log-schema:check": "node tooling/check-log-schema.mjs",
		"governance:run-correlation:check": "node tooling/check-run-correlation.mjs",
		"governance:observability:check": "node tooling/check-log-schema.mjs && node tooling/check-evidence-governance.mjs && node tooling/check-run-correlation.mjs",
		"governance:no-wild-log:check": "node tooling/check-no-wild-log.mjs",
		"governance:pinned-source:check": "node tooling/check-pinned-sources.mjs",
		"governance:evidence:check": "node tooling/check-evidence-governance.mjs",
		"governance:cold-start:check": "node tooling/check-cold-start-governance.mjs",
		"governance:language-boundary:check": "node tooling/check-governance-language-boundary.mjs",
		"governance:remote-evidence:check": "node tooling/check-remote-governance-evidence.mjs",
		"governance:remote-evidence:check:strict": "node tooling/check-remote-governance-evidence.mjs --strict",
		"governance:open-source-surface:check": "node tooling/check-open-source-surface.mjs",
		"governance:compat-matrix:check": "node tooling/check-compat-matrix.mjs",
		"governance:patch-registry:check": "node tooling/check-patch-registry.mjs",
		"governance:upstream-failure-classification:check": "node tooling/check-upstream-failure-classification.mjs",
		"governance:upstream:check": "npm run -s governance:pinned-source:check && node tooling/check-upstream-governance.mjs && npm run -s governance:compat-matrix:check && npm run -s governance:patch-registry:check && npm run -s governance:upstream-failure-classification:check",
		"governance:workflow:check": "node tooling/check-workflow-governance.mjs",
		"governance:score:check": "node tooling/check-final-form-score.mjs",
		"governance:final:check": "npm run -s governance:identity-alignment:check && npm run -s governance:language-boundary:check && npm run -s governance:tracked-surface:check && npm run -s governance:open-source-surface:check && npm run -s governance:remote-evidence:check && npm run -s governance:ssot:check && npm run -s governance:topology:check && npm run -s governance:public-surface:check && npm run -s governance:module-readme:check && npm run -s governance:root:check && npm run -s governance:root-pristine:check && npm run -s governance:deps:check && npm run -s governance:delivery-surface:check && npm run -s governance:history-hygiene:check && npm run -s governance:runtime:check && npm run -s governance:runtime-layout:check && npm run -s governance:cache-lifecycle:check && npm run -s host:safety:check && npm run -s governance:space:check && npm run -s governance:upstream-policy:check && npm run -s governance:log-schema:check && npm run -s governance:evidence:check && npm run -s governance:run-correlation:check && npm run -s governance:no-wild-log:check && npm run -s governance:pinned-source:check && npm run -s governance:upstream:check && npm run -s governance:workflow:check && npm run -s iac:check && npm run -s governance:score:check && npm run -s verify:clean-room",
		"governance:dup:check": "node tooling/check-file-governance.mjs --check-duplicates",
		"governance:file-size:check": "node tooling/check-file-governance.mjs",
		"governance:tracked-surface:check": "node tooling/check-tracked-surface-hygiene.mjs",
		"hooks:install": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
		"iac:check": "node tooling/check-iac-consistency.mjs",
		"lint": "npm run -s lint:biome",
		"lint:backend": "eslint \"services/mcp-server/src/**/*.ts\" \"tooling/**/*.mjs\" \"tooling/**/*.ts\" \"*.{js,mjs,cjs,ts}\"",
		"lint:biome": "biome lint --diagnostic-level=error --files-ignore-unknown=true services/mcp-server/src tests tooling package.json biome.json",
		"lint:staged": "biome lint --diagnostic-level=error --files-ignore-unknown=true --no-errors-on-unmatched --staged",
		"lint:eslint": "eslint \"services/mcp-server/src/**/*.ts\" \"tests/**/*.ts\" \"tooling/**/*.mjs\" \"tooling/**/*.ts\" \"*.{js,mjs,cjs,ts}\"",
		"lint:fix": "eslint \"services/mcp-server/src/**/*.ts\" \"tests/**/*.ts\" \"tooling/**/*.mjs\" \"tooling/**/*.ts\" \"*.{js,mjs,cjs,ts}\" --fix",
		"lint:frontend": "eslint \"tests/**/*.ts\"",
		"mutation:gate": "node tooling/check-core-coverage.mjs --mutation-only",
		"mutation:cleanup": "node tooling/clean-mutation-worktrees.mjs",
		"mutation:run": "npm run -s mutation:run:full",
		"mutation:run:full": "node tooling/run-mutation-smoke.mjs --mode=full",
		"mutation:run:quick": "node tooling/run-mutation-smoke.mjs --mode=quick",
		"mutation:run:gate": "npm run -s mutation:run:full && npm run -s mutation:gate",
		"patch:apply": "patch-package --patch-dir ops/upstream/patches/patch-package",
		"patch:create": "patch-package --patch-dir ops/upstream/patches/patch-package",
		"pages:build": "OPENUI_DEPLOY_TARGET=github-pages npm --workspace apps/web run build",
		"postinstall": "node tooling/apply-patches-if-present.mjs",
		"preprepare:next-app": "node -e \"process.exit(0)\"",
		"precommit:container": "node tooling/check-container-env.mjs --require-container && npm run precommit:gate",
		"precommit:docs:cochange": "node --unhandled-rejections=strict tooling/check-docs-cochange.mjs",
		"precommit:gate": "node --unhandled-rejections=strict tooling/precommit-gate.mjs",
		"prepush:gate": "PRECOMMIT_GATE_PROFILE=prepush-light npm run -s precommit:gate",
		"prepare": "npm run -s hooks:install",
		"prepare:next-app": "tsx tooling/prepare-next-app.ts",
		"public:assets:check": "node tooling/render-public-assets.mjs --check",
		"public:assets:optimize": "node tooling/optimize-png-assets.mjs",
		"public:assets:render": "node tooling/render-public-assets.mjs && npm run -s public:assets:optimize -- docs/assets",
		"public:remote:check": "node tooling/check-public-surface-live.mjs",
		"public:surface:check": "npm run -s public:assets:check && npm run -s public:remote:check",
		"proof:pack:check": "node tooling/check-proof-pack-freshness.mjs",
		"py:format:check": "python3 -m ruff format --check services/gemini-sidecar",
		"py:health": "node --env-file-if-exists=.env tooling/run-python-with-env.mjs tooling/python-sidecar-health.py",
		"py:lint": "python3 -m ruff check services/gemini-sidecar",
		"py:setup": "python3 -m pip install -r services/gemini-sidecar/requirements.txt",
		"py:smoke": "node --env-file-if-exists=.env tooling/run-python-with-env.mjs tooling/python-sidecar-health.py --smoke",
		"quality:trend": "node tooling/quality-trend.mjs --window=30d",
		"quality:calibrate": "node tooling/quality-score-calibrate.mjs",
		"release:readiness:check": "node tooling/check-release-readiness.mjs",
		"release:public-safe:check": "npm run -s docs:check:strict && node tooling/check-release-readiness.mjs --strict-authoritative-runs && npm run -s governance:remote-evidence:check:strict && npm run -s governance:history-hygiene:check && npm run -s security:history:sensitive:audit && npm run -s security:github:public:audit && npm run -s security:dependency-review:check && npm run -s security:zizmor:audit && npm run -s security:trivy:audit",
		"repo:clean": "node tooling/cli/repo-clean.mjs",
		"repo:browser:bootstrap": "node --env-file-if-exists=.env tooling/cli/repo-browser-bootstrap.mjs",
		"repo:browser:status": "node --env-file-if-exists=.env tooling/cli/repo-browser-status.mjs",
		"repo:browser:verify": "node --env-file-if-exists=.env tooling/cli/repo-browser-verify.mjs",
		"repo:doctor": "node --env-file-if-exists=.env tooling/cli/repo-doctor.mjs",
		"repo:workflow:summary": "node --import tsx tooling/cli/repo-workflow-summary.ts",
		"repo:workflow:ready": "node --import tsx tooling/cli/repo-workflow-ready.mjs",
		"repo:space:check": "npm run -s governance:space:check",
		"repo:space:clean": "node --env-file-if-exists=.env tooling/space-clean.mjs",
		"repo:space:clean:dry-run": "node --env-file-if-exists=.env tooling/space-clean-dry-run.mjs",
		"repo:space:maintain": "node --env-file-if-exists=.env tooling/space-maintain.mjs --apply",
		"repo:space:maintain:dry-run": "node --env-file-if-exists=.env tooling/space-maintain.mjs",
		"repo:space:report": "node --env-file-if-exists=.env tooling/space-governance-report.mjs",
		"repo:space:verify": "node --env-file-if-exists=.env tooling/space-verify-candidates.mjs",
		"repo:upstream:check": "node tooling/cli/repo-upstream-check.mjs",
		"repo:verify:fast": "node tooling/cli/repo-verify-fast.mjs",
		"repo:verify:clean-room": "node tooling/cli/repo-verify-clean-room.mjs",
		"repo:verify:full": "node tooling/cli/repo-verify-full.mjs",
		"repo:verify:live": "node --env-file-if-exists=.env tooling/cli/repo-verify-live.mjs",
		"resource:leak:check": "node tooling/check-resource-leaks.mjs",
		"resource:leak:check:staged": "node tooling/check-resource-leaks.mjs --staged",
		"rollback:drill": "git config user.name \"rollback-drill\" && git config user.email \"rollback-drill@local\" && git switch -c rollback-drill-$(date +%Y%m%d%H%M%S) && git commit --allow-empty -m \"ci: rollback drill marker\" && marker=$(git rev-parse HEAD) && git revert --no-edit \"$marker\" && git log --oneline -2",
		"security:git-secrets:history": "bash tooling/git-secrets-history-audit.sh",
		"security:history:audit": "bash tooling/history-secrets-audit.sh",
		"security:history:sensitive:audit": "node tooling/history-sensitive-surface-audit.mjs",
		"security:github:public:audit": "node tooling/github-sensitive-surface-review.mjs",
		"security:dependency-review:check": "node tooling/dependency-review-local.mjs && node tooling/check-supplemental-security-wiring.mjs --tool=dependency-review",
		"security:dependency-review:local": "node tooling/dependency-review-local.mjs",
		"security:evidence:final": "node tooling/security-final-evidence.mjs",
		"security:oss:audit": "bash tooling/oss-security-audit.sh",
		"security:pii:audit": "node tooling/pii-audit.mjs",
		"security:sensitive-surface:audit": "node tooling/sensitive-surface-audit.mjs",
		"security:scancode:keyfiles": "bash tooling/scancode-keyfiles-audit.sh",
		"security:trivy:audit": "bash tooling/trivy-audit.sh",
		"security:trivy:check": "node tooling/check-supplemental-security-wiring.mjs --tool=trivy",
		"security:trufflehog:audit": "bash tooling/trufflehog-audit.sh",
		"security:zizmor:audit": "bash tooling/zizmor-audit.sh",
		"security:zizmor:check": "node tooling/check-supplemental-security-wiring.mjs --tool=zizmor",
		"governance:remote:review": "node tooling/remote-canonical-review.mjs",
		"presmoke:e2e": "npm run -s prepare:next-app",
		"smoke:e2e": "tsx tooling/run-next-smoke.ts",
		"skills:install:proof": "node tooling/skills-install-proof.mjs",
		"start": "node --env-file-if-exists=.env .runtime-cache/build/mcp-server/services/mcp-server/src/main.js",
		"stress:all": "node --env-file-if-exists=.env --import tsx tooling/stress-sidecar-computer-use.ts --target=all",
		"stress:computer-use": "node --env-file-if-exists=.env --import tsx tooling/stress-sidecar-computer-use.ts --target=computer-use",
		"stress:sidecar": "node --env-file-if-exists=.env --import tsx tooling/stress-sidecar-computer-use.ts --target=sidecar",
		"sync:upstream:check": "node tooling/sync-upstream-check.mjs",
		"sync:upstream:dryrun": "node tooling/sync-upstream-dryrun.mjs",
		"sync:upstream:init": "node tooling/sync-upstream-init.mjs",
		"test": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run",
		"test:acceptance:gate": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run tests/advanced-feature-policy.test.ts tests/structured-output-enforcement.test.ts tests/docs-completeness-gate.test.ts",
		"test:coverage": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run --coverage",
		"test:e2e": "playwright test --config=playwright.config.ts",
		"test:e2e:external": "RUN_EXTERNAL_E2E=1 playwright test --config=playwright.config.ts tests/e2e/external-site-readonly.spec.ts --project=chromium",
		"test:e2e:resilience": "playwright test --config=playwright.config.ts tests/e2e/network-resilience.spec.ts --project=chromium",
		"test:fast:gate": "npm run -s test:unit:gate && npm run -s test:integration:gate && npm run -s test:acceptance:gate",
		"test:integration:gate": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run tests/openui-client.test.ts tests/retriever.test.ts tests/rag-upsert-search.test.ts tests/mcp-integration.test.ts tests/apply-rollback.test.ts tests/runtime-config.test.ts tests/e2e-no-hard-wait.test.ts",
		"test:live": "node tooling/run-live-tests.mjs",
		"test:unit:gate": "node --env-file-if-exists=.env ./node_modules/vitest/vitest.mjs run tests/path-utils.test.ts tests/json-utils.test.ts tests/process-utils.test.ts tests/child-env.test.ts",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"uiux:audit": "node --env-file-if-exists=.env --import tsx tooling/uiux-ai-audit.ts",
		"uiux:audit:full": "node --env-file-if-exists=.env --import tsx tooling/uiux-ai-audit.ts --strict --full-site --vision",
		"uiux:a11y:axe": "node --import tsx tooling/uiux-a11y-engine.ts",
		"uiux:audit:strict": "npm run -s uiux:audit -- --strict --full-site --max-warnings=0",
		"uiux:audit:strict:gate": "npm run -s uiux:audit:strict && npm run -s uiux:a11y:axe -- --strict --mode=changed",
		"uiux:audit:vision": "npm run -s uiux:audit -- --vision --strict",
		"visual:qa": "tsx tooling/visual-qa.ts",
		"visual:qa:update": "tsx tooling/visual-qa.ts --update && npm run -s public:assets:optimize -- tests/visual-golden",
		"verify:clean-room": "node tooling/verify-clean-room.mjs"
	},
	"type": "module",
	"version": "0.3.0"
}
